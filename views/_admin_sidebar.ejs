<script>
(function() {
  var sl = document.querySelector('.sidebar-links');
  if (!sl) return;
  var saved = sessionStorage.getItem('admin_sidebar_scroll');
  if (saved) { sl.scrollTop = parseInt(saved, 10); }
  sl.addEventListener('scroll', function() {
    sessionStorage.setItem('admin_sidebar_scroll', sl.scrollTop);
  });
  document.querySelectorAll('.side-link').forEach(function(link) {
    link.addEventListener('click', function() {
      sessionStorage.setItem('admin_sidebar_scroll', sl.scrollTop);
    });
  });
})();
function toggleSidebar() {
  var sb = document.getElementById('adminSidebar');
  var ov = document.getElementById('sidebarOverlay');
  sb.classList.toggle('open');
  ov.classList.toggle('active');
}
function closeSidebar() {
  var sb = document.getElementById('adminSidebar');
  var ov = document.getElementById('sidebarOverlay');
  sb.classList.remove('open');
  ov.classList.remove('active');
}
document.querySelectorAll('.side-link').forEach(function(l) {
  l.addEventListener('click', function() { closeSidebar(); });
});
function filterSidebar(q) {
  var links = document.querySelectorAll('.sidebar-links .side-link');
  var sections = document.querySelectorAll('.sidebar-links .side-section');
  q = q.toLowerCase().trim();
  if (!q) {
    links.forEach(function(l) { l.style.display = ''; });
    sections.forEach(function(s) { s.style.display = ''; });
    return;
  }
  links.forEach(function(l) {
    var txt = (l.getAttribute('data-text') || l.textContent || '').toLowerCase();
    l.style.display = txt.indexOf(q) > -1 ? '' : 'none';
  });
  sections.forEach(function(s) {
    var next = s.nextElementSibling;
    var hasVisible = false;
    while (next && !next.classList.contains('side-section')) {
      if (next.classList.contains('side-link') && next.style.display !== 'none') hasVisible = true;
      next = next.nextElementSibling;
    }
    s.style.display = hasVisible ? '' : 'none';
  });
}
</script>