<!doctype html>
<html lang="en-IN">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Change Password | Nastige</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/user-panel.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
</head>
<body>
  <div class="page-wrapper">
    <div class="page-header">
      <div class="page-header-left">
        <img src="/brand/logo" class="page-header-logo" alt="Logo" onerror="this.style.display='none'"/>
        <div>
          <h2 style="margin:0; font-size:20px;">Change Password</h2>
          <p style="margin:4px 0 0; opacity:0.9; font-size:13px;">Update Your Password</p>
        </div>
      </div>
      <div class="page-header-right">
        <a href="/dashboard" class="back-btn"><i class="fas fa-arrow-left"></i> Dashboard</a>
      </div>
    </div>
<div class="nav-bar">
  <a href="/dashboard" class="nav-link">Dashboard</a>
  <a href="/my-offers" class="nav-link">Offers</a>
  <a href="/products" class="nav-link">Products</a>
  <a href="/pins" class="nav-link">My Pins</a>
  <a href="/my-tree" class="nav-link">Tree</a>
  <a href="/downline" class="nav-link">Downline</a>
  <a href="/transactions" class="nav-link">Transactions</a>
  <a href="/my-ranks" class="nav-link">Ranks</a>
  <a href="/invoices" class="nav-link">Invoices</a>
  <a href="/tickets" class="nav-link">Support</a>
  <a href="/kyc" class="nav-link">KYC</a>
  <a href="/profile" class="nav-link active">Profile</a>
  <a href="/my-id-card" class="nav-link">ID Card</a>
</div>
<div class="content"><% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <div class="card" style="max-width:500px; margin:0 auto;">
      <div class="card-header"><i class="fas fa-lock" style="color:#667eea; margin-right:8px;"></i> Change Password</div>
      <div class="card-body">
        <form method="post" action="/password">
          <div class="form-group">
            <label><i class="fas fa-key"></i> Current Password</label>
            <input name="current_password" type="password" class="form-control" placeholder="Enter current password" required/>
          </div>
          <div class="form-group">
            <label><i class="fas fa-lock"></i> New Password</label>
            <input name="new_password" type="password" class="form-control" placeholder="Enter new password (min 6 characters)" required minlength="6"/>
          </div>
          <div class="form-group">
            <label><i class="fas fa-lock"></i> Confirm New Password</label>
            <input name="confirm_password" type="password" class="form-control" placeholder="Confirm new password" required minlength="8"/>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;"><i class="fas fa-save"></i> Update Password</button>
        </form>
      </div>
    </div>
  </div>
  </div>
  </div>
<script>document.querySelectorAll('.side-link').forEach(function(l){var p=l.getAttribute('href');if(window.location.pathname===p||(p!=='/admin'&&window.location.pathname.startsWith(p)))l.classList.add('active')});</script>
</body>
</html>
