  <style>
    :root {
      --primary: #667eea;
      --secondary: #764ba2;
      --accent: #f093fb;
      --dark: #0b5ed7;
      --gold: #f7971e;
      --text-dark: #1a202c;
      --text-light: #718096;
      --bg-light: #f8fafc;
      --white: #ffffff;
      --shadow: 0 4px 6px rgba(0,0,0,0.1);
      --radius: 12px;
    }

    * { box-sizing: border-box; }

    /* Side Popup Styles - Always Visible */
    .side-popup-fixed {
      position: fixed;
      right: 0;
      bottom: 52px;
      z-index: 999999;
      animation: slideInRight 0.5s ease;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
    }
    
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(100%); }
      to { opacity: 1; transform: translateX(0); }
    }
    
    .side-popup-header {
      background: #10b981;
      color: white;
      padding: 5px 6px 2px 6px;
      border-radius: 8px 0 0 0;
      text-align: right;
      min-width: 70px;
    }
    
    .side-popup-header h3 {
      margin: 0 0 1px 0;
      font-size: 10px;
      font-weight: 700;
      line-height: 1.2;
    }
    
    .side-popup-header p {
      margin: 0;
      font-size: 8px;
      opacity: 0.9;
      line-height: 1.2;
    }
    
    .side-popup-link {
      display: block;
      background: #10b981;
      color: white;
      text-decoration: none;
      padding: 5px 6px;
      border-radius: 0 0 0 8px;
      font-size: 9px;
      font-weight: 600;
      text-align: center;
      min-width: 70px;
      box-shadow: -2px 2px 6px rgba(0,0,0,0.15);
      transition: background 0.3s;
    }
    
    .side-popup-link:hover {
      background: #059669;
    }
    
    /* Mobile Side Popup */
    @media (max-width: 768px) {
      .side-popup-fixed {
        right: 0;
        bottom: 60px;
      }
      .side-popup-header { min-width: 80px; padding: 6px 8px 3px 8px; }
      .side-popup-header h3 { font-size: 11px; }
      .side-popup-header p { font-size: 9px; }
      .side-popup-link { min-width: 80px; padding: 7px 8px; font-size: 10px; }
    }
    
    @media (max-width: 480px) {
      .side-popup-fixed { bottom: 50px; }
      .side-popup-header { min-width: 70px; padding: 5px 6px 2px 6px; }
      .side-popup-header h3 { font-size: 10px; }
      .side-popup-header p { font-size: 8px; }
      .side-popup-link { min-width: 70px; padding: 6px 6px; font-size: 9px; }
    }


    /* Prevent selection only on images and specific elements */
    img {
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      user-select: none;
    }

    /* Top Bar */
    .og-topbar {
      background: #ff6b00;
      color: white;
      padding: 8px 0;
      font-size: 13px;
      text-align: center;
      letter-spacing: 0.5px;
      font-weight: 600;
    }

    .og-topbar .wrap {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 20px;
    }

    .hotline {
      font-weight: 600;
      background: rgba(255,255,255,0.15);
      padding: 4px 12px;
      border-radius: 20px;
    }

    /* Header */
    .home-header {
      background: white;
      box-shadow: 0 2px 20px rgba(0,0,0,0.06);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .brandbar {
      max-width: 1200px;
      margin: 0 auto;
      padding: 8px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 20px;
      font-weight: 700;
      color: #0b5ed7;
      letter-spacing: -0.5px;
    }

    .brand img, .logo-md {
      height: 90px;
      width: auto;
      max-width: 350px;
      object-fit: contain;
    }

    .topsearch {
      flex: 1;
      max-width: 500px;
      display: flex;
      gap: 8px;
    }

    .topsearch input {
      flex: 1;
      padding: 12px 16px;
      border: 2px solid #e2e8f0;
      border-radius: 12px;
      font-size: 14px;
      transition: all 0.3s ease;
      background: #f8fafc;
    }

    .topsearch input:focus {
      outline: none;
      border-color: #0b5ed7;
      background: white;
      box-shadow: 0 0 0 4px rgba(11, 94, 215, 0.1);
    }

    .topsearch button {
      padding: 12px 24px;
      background: var(--primary);
      border: none;
      border-radius: 12px;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .topsearch button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
    }

    .btn-row {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .btn {
      padding: 12px 24px;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.3s ease;
      display: inline-block;
      border: none;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
      box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    .btn-secondary {
      background: white;
      color: #0b5ed7;
      border: 2px solid #e2e8f0;
    }

    .btn-secondary:hover {
      border-color: #0b5ed7;
      background: #f8fafc;
    }

    /* Navigation */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    

    .nav-bar .nav-menu {
      display: flex;
      flex: 1;
      justify-content: center;
      align-items: center;
      gap: 4px;
      flex-wrap: nowrap;
      overflow-x: auto;
    }
    .nav-bar .nav-menu::-webkit-scrollbar { display: none; }

    .nav-bar .nav-menu .nav-link {
      display: inline-flex;
      align-items: center;
      padding: 8px 16px;
      border-radius: 20px;
      color: #e5e7eb;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      white-space: nowrap;
      border: 1px solid transparent;
      transition: all 0.2s;
      background: transparent;
    }
    .nav-bar .nav-menu .nav-link:hover {
      background: rgba(255,255,255,0.1);
      border-color: rgba(255,255,255,0.15);
      color: #fff;
    }
    .nav-bar .nav-menu .nav-link.active {
      background: rgba(255,255,255,0.15);
      border-color: rgba(255,255,255,0.2);
      color: #fff;
    }
    .nav-bar .nav-menu a:nth-last-of-type(3) { color: #10b981; border-color: #10b981; background: rgba(16,185,129,0.1); }
    .nav-bar .nav-menu a:nth-last-of-type(2) { color: #3b82f6; border-color: #3b82f6; background: rgba(59,130,246,0.1); }
    .nav-bar .nav-menu a:nth-last-of-type(1) { color: #f59e0b; border-color: #f59e0b; background: rgba(245,158,11,0.1); }
    .nav-bar .nav-menu a:nth-last-of-type(3):hover { background: #10b981; color: #fff; }
    .nav-bar .nav-menu a:nth-last-of-type(2):hover { background: #3b82f6; color: #fff; }
    .nav-bar .nav-menu a:nth-last-of-type(1):hover { background: #f59e0b; color: #fff; }

    .nav-menu span {
      width: 1px;
      height: 24px;
      background: #555;
      margin: 0 8px;
      flex-shrink: 0;
    }

    .mobile-menu-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px;
      z-index: 1001;
    }

    .mobile-menu-toggle span {
      width: 24px;
      height: 3px;
      background: #333;
      border-radius: 3px;
      transition: all 0.3s ease;
    }

    .mobile-auth-btns {
      display: none;
    }

    .desktop-only {
      display: flex;
    }

    .mobile-auth-btns {
      display: none;
    }

    /* Hero Section */
    .hero-section {
      background: var(--dark);
      border-radius: var(--radius);
      padding: 60px 40px;
      color: white;
      margin: 24px 0;
      box-shadow: var(--shadow);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 40px;
      align-items: center;
    }

    .hero-text h1 {
      font-size: 48px;
      font-weight: 800;
      line-height: 1.1;
      margin: 0 0 16px 0;
      letter-spacing: -1px;
    }

    .hero-text .subtitle {
      font-size: 18px;
      opacity: 0.9;
      margin-bottom: 32px;
      font-weight: 400;
    }

    .hero-buttons {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .hero-cta {
      padding: 16px 32px;
      font-size: 16px;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .cta-primary {
      background: #1bb865;
      color: white;
      box-shadow: 0 8px 25px rgba(27, 184, 101, 0.3);
    }

    .cta-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 35px rgba(27, 184, 101, 0.4);
    }

    .cta-secondary {
      background: rgba(255,255,255,0.15);
      color: white;
      border: 2px solid rgba(255,255,255,0.3);
    }

    .cta-secondary:hover {
      background: rgba(255,255,255,0.25);
      border-color: rgba(255,255,255,0.5);
    }

    .login-card {
      background: white;
      border-radius: 16px;
      padding: 32px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }

    .login-card h3 {
      margin: 0 0 24px 0;
      color: #1a202c;
      font-size: 24px;
      text-align: center;
    }

    .login-card label {
      display: block;
      margin-bottom: 8px;
      color: #475569;
      font-weight: 500;
      font-size: 14px;
    }

    .login-card input {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid #e2e8f0;
      border-radius: 10px;
      font-size: 14px;
      margin-bottom: 20px;
      transition: all 0.2s ease;
    }

    .login-card input:focus {
      outline: none;
      border-color: #0b5ed7;
      box-shadow: 0 0 0 4px rgba(11, 94, 215, 0.1);
    }

    .login-card .btn-row {
      margin-top: 24px;
    }

    .login-card button {
      flex: 1;
      padding: 14px;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .login-card button[type="submit"] {
      background: var(--primary);
      color: white;
    }

    .login-card button[type="submit"]:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    }

    /* Features Section */
    .features-section {
      margin: 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .section-header h2 {
      font-size: 36px;
      font-weight: 800;
      color: #1a202c;
      margin: 0 0 12px 0;
      letter-spacing: -0.5px;
    }

    .section-header p {
      font-size: 18px;
      color: #64748b;
      margin: 0;
    }

    .features-grid {
      display: flex;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .feature-card {
      background: white;
      border-radius: var(--radius);
      padding: 16px 20px;
      box-shadow: var(--shadow);
      transition: all 0.3s ease;
      text-align: center;
      min-width: 200px;
      max-width: 250px;
    }

    .feature-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    .feature-icon {
      width: 40px;
      height: 40px;
      background: var(--primary);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 12px;
      font-size: 20px;
    }

    .feature-card h3 {
      margin: 0 0 8px 0;
      font-size: 14px;
      font-weight: 700;
      color: #1f2937;
    }

    .feature-card p {
      font-size: 12px;
      color: #6b7280;
      margin: 0;
      line-height: 1.4;
    }

    .feature-card p {
      margin: 0;
      color: #64748b;
      line-height: 1.7;
    }

    /* Products Section */
    .products-section {
      margin: 48px 0;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      padding: 20px;
    }

    .product-card {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
      transition: all 0.3s ease;
      position: relative;
      border: 1px solid #e5e7eb;
    }
    
    .product-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(102,126,234,0.15);
      border-color: #667eea;
    }

    .product-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #667eea, #764ba2);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .product-card:hover::before {
      opacity: 1;
    }

    .product-card .category-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background: linear-gradient(135deg, #ff6b9d 0%, #ff8a80 100%);
      color: white;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      z-index: 10;
      box-shadow: 0 4px 12px rgba(255,107,157,0.4);
    }

    .product-image {
      height: 200px;
      background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      position: relative;
      border-bottom: 1px solid #e5e7eb;
    }

    .product-image:hover {
      opacity: 0.9;
    }

    .product-image img {
      pointer-events: none;
      user-select: none;
      -webkit-user-drag: none;
      max-height: 160px;
      object-fit: contain;
    }

    img {
      user-select: none;
      -webkit-user-drag: none;
    }

    .product-badge {
      position: absolute;
      top: 12px;
      right: 12px;
      background: linear-gradient(135deg, #10b981, #059669);
      color: white;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      z-index: 1;
      box-shadow: 0 2px 8px rgba(16,185,129,0.3);
    }

    .product-info {
      padding: 16px 20px 20px;
    }

    .product-label {
      font-size: 10px;
      font-weight: 600;
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 4px;
    }

    .product-info h4 {
      margin: 0 0 8px 0;
      font-size: 16px;
      font-weight: 700;
      color: #1a202c;
      line-height: 1.3;
      text-transform: uppercase;
    }

    .product-rating {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 10px;
    }

    .product-rating .stars {
      color: #fbbf24;
      font-size: 18px;
    }

    .product-rating .count {
      font-size: 14px;
      color: #9ca3af;
    }

    .product-price {
      font-size: 20px;
      font-weight: 800;
      color: #667eea;
    }

    .product-price .label {
      font-size: 12px;
      font-weight: 600;
      color: #64748b;
    }

    .product-actions {
      display: flex;
      gap: 8px;
      margin-top: 4px;
    }

    .btn-view {
      flex: 1;
      text-align: center;
      padding: 10px 12px;
      border: 2px solid #667eea;
      background: transparent;
      color: #667eea;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 13px;
      transition: all 0.2s;
    }

    .btn-view:hover {
      background: #667eea;
      color: #fff;
      transform: translateY(-2px);
    }

    .btn-buy {
      flex: 1;
      text-align: center;
      padding: 10px 12px;
      border: none;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 13px;
      transition: all 0.2s;
      box-shadow: 0 4px 12px rgba(102,126,234,0.3);
    }

    .btn-buy:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(102,126,234,0.4);
    }

    .product-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
      font-size: 14px;
    }

    .bv-badge {
      background: #fef3c7;
      color: #92400e;
      padding: 4px 10px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 12px;
    }

    .price-badge {
      background: #dcfce7;
      color: #166534;
      padding: 4px 10px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 14px;
    }

    .product-actions {
      display: flex;
      gap: 8px;
    }

    .product-actions .btn {
      flex: 1;
      padding: 10px;
      font-size: 13px;
      text-align: center;
    }

    /* Categories Section */
    .categories-section {
      margin: 48px 0;
      background: white;
      border-radius: var(--radius);
      padding: 40px;
      box-shadow: var(--shadow);
    }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
    }

    .category-card {
      background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
      transition: all 0.3s ease;
      cursor: pointer;
      border: 2px solid transparent;
    }

    .category-card:hover {
      border-color: #0b5ed7;
      transform: translateY(-4px);
      box-shadow: 0 12px 30px rgba(0,0,0,0.1);
    }

    .category-icon {
      font-size: 36px;
      margin-bottom: 12px;
    }

    .category-card h4 {
      margin: 0;
      font-size: 14px;
      font-weight: 600;
      color: #475569;
    }

    /* CTA Banner */
    .cta-banner {
      background: var(--gold);
      border-radius: var(--radius);
      padding: 48px;
      text-align: center;
      color: white;
      margin: 48px 0;
      box-shadow: var(--shadow);
    }

    .cta-banner h2 {
      font-size: 36px;
      font-weight: 800;
      margin: 0 0 16px 0;
      position: relative;
      z-index: 1;
    }

    .cta-banner p {
      font-size: 18px;
      margin: 0 0 32px 0;
      opacity: 0.95;
      position: relative;
      z-index: 1;
    }

    .cta-banner .btn {
      padding: 16px 40px;
      font-size: 16px;
      background: white;
      color: #f7971e;
      border: none;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      z-index: 1;
      box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    }

    .cta-banner .btn:hover {
      transform: translateY(-4px) scale(1.05);
      box-shadow: 0 12px 35px rgba(0,0,0,0.3);
    }

    /* Trust Section */
    .trust-section {
      margin: 48px 0;
      text-align: center;
    }

    .trust-badges {
      display: flex;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .trust-badge {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .trust-icon {
      width: 60px;
      height: 60px;
      background: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .trust-badge span {
      font-size: 13px;
      color: #64748b;
      font-weight: 500;
    }

    /* Gallery Section */
    .gallery-section {
      margin: 48px 0;
      padding: 32px 20px;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(10, 1fr);
      gap: 8px;
      margin-top: 16px;
    }
    @media(max-width:900px){.gallery-grid{grid-template-columns: repeat(5, 1fr) !important;}}
    @media(max-width:500px){.gallery-grid{grid-template-columns: repeat(3, 1fr) !important;}}

    .gallery-item {
      position: relative;
      border-radius: 8px;
      overflow: hidden;
      aspect-ratio: 1;
      background: #f1f5f9;
    }

    .gallery-item img, .gallery-item video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .gallery-item:hover img, .gallery-item:hover video {
      transform: scale(1.08);
    }

    .gallery-item::after {
      content: '\1F50D';
      position: absolute;
      top: 4px;
      right: 4px;
      width: 22px;
      height: 22px;
      background: rgba(0,0,0,0.5);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      opacity: 0;
      transition: opacity 0.2s;
    }

    .gallery-item:hover::after {
      opacity: 1;
    }

    .gallery-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0,0,0,0.8));
      color: white;
      padding: 32px 16px 16px;
      font-size: 14px;
      font-weight: 500;
    }

    .gallery-placeholder {
      grid-column: 1 / -1;
      text-align: center;
      padding: 48px;
      background: #f8fafc;
      border-radius: 12px;
      color: #64748b;
    }

    .video-item::before {
      content: '▶';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 50px;
      height: 50px;
      background: rgba(0,0,0,0.7);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 20px;
      z-index: 1;
    }

    /* Rank Achievers Section */
    .achievers-section {
      margin: 48px 0;
      padding: 32px 20px;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .achievers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
      margin-top: 24px;
    }

    .achiever-card {
      background: white;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      transition: transform 0.3s ease;
    }

    .achiever-card:hover {
      transform: translateY(-5px);
    }

    .achiever-photo {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      margin: 0 auto 10px;
      border: 3px solid #667eea;
      pointer-events: none;
      user-select: none;
      -webkit-user-drag: none;
    }

    .achiever-icon {
      font-size: 40px;
      margin-bottom: 10px;
    }

    .achiever-name {
      font-weight: 600;
      color: #1a202c;
      font-size: 16px;
    }

    /* Latest Rank Achievers Section */
    .latest-achievers-section {
      margin: 48px 0;
      padding: 32px 20px;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 20px;
      color: white;
    }

    .latest-achievers-section .section-header h2 {
      color: white;
    }

    .latest-achievers-section .section-header p {
      color: rgba(255,255,255,0.8);
    }

    .latest-achievers-grid {
      display: flex;
      gap: 20px;
      margin-top: 24px;
      overflow: hidden;
      position: relative;
    }
    
    <% var achSpeed = (typeof achieversMarqueeSpeed !== 'undefined' && achieversMarqueeSpeed) ? parseInt(achieversMarqueeSpeed) : 40; %>
    .latest-achievers-track {
      display: flex;
      gap: 20px;
      animation: scrollLeft <%= achSpeed %>s linear infinite;
    }
    
    .latest-achievers-track:hover {
      animation-play-state: paused;
    }
    
    @keyframes scrollLeft {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .latest-achievers-section .achiever-card {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      color: white;
    }

    .latest-achievers-section .achiever-name {
      color: white;
    }

    .latest-achievers-section .achiever-rank {
      color: #ffd700;
    }

    .latest-achievers-section .achiever-icon {
      font-size: 40px;
    }

    .latest-achievers-section .achiever-photo {
      border-color: #ffd700;
    }

    .latest-achievers-section .empty-message {
      background: rgba(255,255,255,0.1);
      color: white;
    }

    .achiever-rank {
      color: #667eea;
      font-size: 14px;
      margin-top: 4px;
      font-weight: 500;
    }

    /* Star Winners Section */
    .star-winners-section {
      margin: 48px 0;
      padding: 32px 20px;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
      background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
      border-radius: 20px;
      color: #1a202c;
    }

    .star-winners-section .section-header h2 {
      color: #1a202c;
    }

    .star-winners-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
      margin-top: 24px;
    }

    .star-winner-card {
      background: #fef3c7;
      border: 1px solid #f59e0b;
      border-radius: 16px;
      padding: 20px;
      text-align: center;
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
      transition: transform 0.3s ease;
    }

    .star-winner-card:hover {
      transform: scale(1.05);
    }

    .star-icon {
      font-size: 40px;
      margin-bottom: 10px;
    }

    .star-name {
      font-weight: 700;
      color: #1d4ed8;
      font-size: 16px;
    }

    .star-badge {
      color: #92400e;
      font-weight: 600;
      margin-top: 8px;
      font-size: 14px;
    }

    /* Founders Section */
    .founders-section {
      margin: 48px 0;
      padding: 32px 20px;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .founders-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
      margin-top: 32px;
    }

    .founder-card {
      background: white;
      border-radius: 16px;
      padding: 30px;
      text-align: center;
      box-shadow: 0 8px 30px rgba(0,0,0,0.1);
      transition: transform 0.3s ease;
    }

    .founder-card:hover {
      transform: translateY(-10px);
    }

    .founder-image {
      width: 150px;
      height: 150px;
      margin: 0 auto 20px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid #667eea;
      background: #f5f5f5;
    }

    .founder-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 50% 30%;
      pointer-events: none;
      user-select: none;
      -webkit-user-drag: none;
    }

    .founder-image.position-top img { object-position: 50% 10%; }
    .founder-image.position-center img { object-position: 50% 30%; }
    .founder-image.position-bottom img { object-position: 50% 70%; }

    .founder-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f1f5f9;
      font-size: 60px;
    }

    .founder-name {
      font-size: 20px;
      font-weight: 700;
      color: #1a202c;
      margin-bottom: 4px;
    }

    .founder-title {
      color: #667eea;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 16px;
    }

    .founder-message {
      color: #64748b;
      font-size: 14px;
      line-height: 1.6;
      font-style: italic;
    }

    .empty-message {
      grid-column: 1 / -1;
      text-align: center;
      padding: 40px;
      background: #f8fafc;
      border-radius: 12px;
      color: #64748b;
    }

    /* Footer */
    .footer {
      background: #1a202c;
      color: white;
      padding: 48px 0 24px;
      margin-top: 48px;
    }

    .footer-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 40px;
    }

    .footer-section h4 {
      margin: 0 0 16px 0;
      font-size: 16px;
      font-weight: 600;
      color: #f1f5f9;
    }

    .footer-section ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .footer-section li {
      margin-bottom: 8px;
    }

    .footer-section a {
      color: #cbd5e0;
      text-decoration: none;
      font-size: 14px;
      transition: color 0.2s ease;
    }

    .footer-section a:hover {
      color: white;
    }

    .footer-bottom {
      max-width: 1200px;
      margin: 32px auto 0;
      padding: 24px 20px 0;
      border-top: 1px solid #2d3748;
      text-align: center;
      color: #a0aec0;
      font-size: 14px;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .achievers-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      }
      .latest-achievers-grid {
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      }
      .footer-content {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .hero-content {
        grid-template-columns: 1fr;
      }

      .hero-text h1 {
        font-size: 28px;
      }

      .hero-text p {
        font-size: 16px;
      }

      .brandbar {
        flex-wrap: wrap;
        padding: 10px 16px;
        gap: 10px;
      }

      .brandbar .brand {
        font-size: 16px;
      }

      .brandbar .brand img {
        max-width: 140px;
        max-height: 50px;
        height: 50px;
      }

      .topsearch {
        order: 3;
        flex: 0 0 100%;
        max-width: 100%;
        margin-top: 10px;
      }

      .desktop-only {
        display: none !important;
      }

      .mobile-menu-toggle {
        display: flex !important;
      }

      

      .nav-bar .nav-menu {
        display: none;
        flex-direction: column;
        background: #1a1a1a;
      padding: 4px 0;
        width: auto;
      }

      .nav-bar .nav-menu.show {
        display: flex;
      }

      .nav-bar .nav-menu .nav-link {
        padding: 10px 16px;
        border-bottom: 1px solid #333;
      }

      .nav-menu span {
        display: none;
      }

      .mobile-auth-btns {
        display: flex !important;
        flex-direction: column;
        gap: 8px;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #e2e8f0;
      }

      .mobile-auth-btns .btn {
        width: 100%;
        text-align: center;
        padding: 12px;
      }

      .hero-section {
        padding: 30px 16px;
      }

      .features-grid,
      .products-grid,
      .categories-section .categories-grid {
        grid-template-columns: 1fr;
      }

      /* Sections */
      .achievers-section,
      .latest-achievers-section,
      .star-winners-section,
      .founders-section,
      .trust-section,
      .gallery-section {
        margin: 24px 0;
        padding: 24px 16px;
        border-radius: 16px;
      }

      .section-header h2 {
        font-size: 24px;
      }

      .section-header p {
        font-size: 14px;
      }

      /* Achievers Grid */
      .achievers-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      .achiever-card {
        padding: 16px;
      }

      .achiever-photo {
        width: 60px;
        height: 60px;
        pointer-events: none;
      }

      .achiever-name {
        font-size: 14px;
      }

      /* Latest Achievers */
      .latest-achievers-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      .latest-achievers-section .achiever-card {
        padding: 16px;
      }

      .latest-achievers-section .achiever-name {
        font-size: 13px;
      }

      .latest-achievers-section .achiever-rank {
        font-size: 11px;
      }

      .latest-achievers-section .achiever-icon {
        font-size: 30px;
      }

      .latest-achievers-section .achiever-photo {
        width: 60px;
        height: 60px;
      }

      /* Star Winners */
      .star-winners-section .section-header h2 {
        font-size: 22px;
      }

      /* Gallery */
      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }

      .gallery-item {
        aspect-ratio: 1;
      }

      /* Footer */
      .footer {
        padding: 32px 16px 20px;
      }

      .footer-content {
        grid-template-columns: 1fr 1fr;
      }

      .footer-bottom {
        padding: 16px;
      }

      .social-icon {
        width: 36px;
        height: 36px;
      }

      .social-sidebar-btn {
        width: 38px;
        height: 38px;
      }

      .footer-section h4 {
        font-size: 16px;
        margin-bottom: 12px;
      }

    .footer-bottom {
      text-align: center;
      padding-top: 20px;
      margin-top: 15px;
      border-top: 1px solid #333;
      color: #888;
      font-size: 14px;
    }

    .social-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 8px;
      color: white;
      transition: transform 0.2s, opacity 0.2s;
    }

    .social-icon:hover {
      transform: translateY(-3px);
      opacity: 0.9;
    }

    .social-icon.facebook { background: #1877f2; }
    .social-icon.x { background: #000000; }
    .social-icon.instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
    .social-icon.youtube { background: #ff0000; }

    /* Floating Social Sidebar */
    .social-sidebar {
      position: fixed;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      z-index: 9998;
      display: flex;
      flex-direction: column;
      gap: 0;
      background: #fff;
      padding: 10px 0;
      border-radius: 0 10px 10px 0;
      box-shadow: 2px 2px 10px rgba(0,0,0,0.2);
    }

    .social-sidebar-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      color: white !important;
      background-color: #333;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .social-sidebar-btn:hover {
      padding-left: 8px;
    }

    .social-sidebar-btn.facebook { background: #1877f2; }
    .social-sidebar-btn.x { background: #000000; color: #ffffff; }
    .social-sidebar-btn.instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
    .social-sidebar-btn.youtube { background: #ff0000; }

      /* Video Section */
      .video-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .hero-text h1 {
        font-size: 24px;
      }

      .btn-row .btn {
        width: 100%;
        text-align: center;
      }

      .achievers-grid {
        grid-template-columns: 1fr 1fr;
      }

      .brandbar .brand span {
        display: none;
      }

      .og-topbar {
        font-size: 11px;
        padding: 6px 0;
      }
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-in {
      animation: fadeInUp 0.6s ease-out forwards;
    }

    /* Mobile Menu */
    @media (max-width: 768px) {
      .mobile-menu-toggle {
        display: flex !important;
      }
      
      .mobile-menu-toggle.active span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
      }
      
      .mobile-menu-toggle.active span:nth-child(2) {
        opacity: 0;
      }
      
      .mobile-menu-toggle.active span:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
      }
    }

    /* ===== Comprehensive Mobile Responsive ===== */
    @media (max-width: 768px) {
      /* General */
      .container, .wrap { padding: 0 12px; }
      section, .section { padding: 20px 12px; margin: 16px 0; }
      
      /* Top Bar */
      .og-topbar { font-size: 11px; padding: 6px 0; }
      .og-topbar .wrap { flex-direction: column; gap: 4px; }
      
      /* Header */
      .brandbar { padding: 8px 12px; gap: 10px; }
      .brand { font-size: 14px; gap: 6px; }
      .brand img { max-height: 45px; max-width: 120px; height: 45px; }
      .brand span { display: none; }
      .topsearch { margin-top: 6px; }
      .topsearch input { font-size: 14px; padding: 10px 12px; }
      
      /* Hero */
      .hero-section { padding: 20px 12px; min-height: auto; }
      .hero-content { grid-template-columns: 1fr !important; gap: 16px; }
      .hero-text h1 { font-size: 22px; line-height: 1.3; }
      .hero-text p { font-size: 14px; }
      .hero-image img { max-width: 100%; height: auto; }
      .btn-row { flex-direction: column; gap: 8px; }
      .btn-row .btn { width: 100%; text-align: center; padding: 12px; }
      
      /* Features */
      .features-grid { grid-template-columns: 1fr !important; gap: 12px; }
      .feature-card { padding: 16px; }
      .feature-card h3 { font-size: 16px; }
      .feature-card p { font-size: 13px; }
      
      /* Products */
      .products-grid { grid-template-columns: 1fr !important; gap: 12px; }
      .product-card { padding: 12px; }
      
      /* Categories */
      .categories-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 10px; }
      
      /* Trust Section */
      .trust-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 10px; }
      
      /* Star Winners & Achievers */
      .star-winners-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 10px; }
      .achievers-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 12px; }
      
      /* Founders */
      .founders-grid { grid-template-columns: 1fr !important; }
      
      /* Gallery */
      .gallery-grid { grid-template-columns: repeat(3, 1fr) !important; gap: 6px; }
      
      /* Video */
      .video-grid { grid-template-columns: 1fr !important; }
      
      /* Footer */
      .footer { padding: 24px 12px 16px; }
      .footer-content { grid-template-columns: 1fr !important; gap: 20px; }
      .footer-section { text-align: center; }
      
      /* Social Sidebar */
      .social-sidebar { display: none; }
      
      /* Tables */
      table { font-size: 12px; }
      th, td { padding: 6px 4px; }
      
      /* Modals */
      .modal-content { width: 95%; margin: 10px; padding: 16px; }
      
      /* Overlays */
      .popup-notice { width: 95%; padding: 16px; }
    }

    @media (max-width: 480px) {
      .hero-text h1 { font-size: 20px; }
      .hero-text p { font-size: 13px; }
      .section-header h2 { font-size: 20px; }
      .section-header p { font-size: 13px; }
      .achievers-grid { grid-template-columns: 1fr 1fr !important; gap: 8px; }
      .achiever-card { padding: 10px; }
      .achiever-photo { width: 50px; height: 50px; }
      .achiever-name { font-size: 12px; }
      .achiever-rank { font-size: 10px; }
      .categories-grid { grid-template-columns: 1fr !important; }
      .trust-grid { grid-template-columns: 1fr !important; }
      .star-winners-grid { grid-template-columns: 1fr !important; }
      .star-winner-card { padding: 12px; }
      .star-winner-card img { width: 50px !important; height: 50px !important; }
      .star-name { font-size: 12px; }
      .gallery-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</head>
<body>
  <%# Popup Notice - Shows on page load %>
  <% if (typeof popup_notice_enabled !== 'undefined' && popup_notice_enabled && typeof popup_notice_message !== 'undefined' && popup_notice_message) { %>
  <div id="popupNoticeOverlay" style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:99999;display:flex;align-items:center;justify-content:center;padding:20px;">
    <div class="popup-content" style="max-width:420px;width:100%;border-radius:16px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.3);animation:popupSlide 0.3s ease;">
      <div class="popup-header" style="background:<%= popup_notice_color || '#667eea' %>;color:white;padding:20px;text-align:center;">
        <h2 style="margin:0;font-size:18px;"><%= popup_notice_title || '📢 Important Notice' %></h2>
      </div>
      <div class="popup-body" style="background:<%= popup_notice_bg || '#ffffff' %>;padding:24px;">
        <p style="margin:0 0 20px 0;color:#374151;font-size:15px;line-height:1.6;white-space:pre-line;"><%= popup_notice_message %></p>
        <% if (popup_notice_button_link && popup_notice_button_link.trim()) { %>
          <a href="<%= popup_notice_button_link %>" style="display:block;background:<%= popup_notice_color || '#667eea' %>;color:white;text-align:center;padding:12px;border-radius:8px;text-decoration:none;font-weight:600;">
            <%= popup_notice_button_text || 'OK, Got it!' %>
          </a>
        <% } else { %>
          <button onclick="document.getElementById('popupNoticeOverlay').style.display='none'" style="display:block;width:100%;background:<%= popup_notice_color || '#667eea' %>;color:white;border:none;padding:12px;border-radius:8px;font-weight:600;cursor:pointer;font-size:15px;">
            <%= popup_notice_button_text || 'OK, Got it!' %>
          </button>
        <% } %>
      </div>
    </div>
  </div>
