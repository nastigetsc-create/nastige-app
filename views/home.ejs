    <!-- Lightbox -->
    <div id="galleryLightbox" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.92); z-index:99999; justify-content:center; align-items:center; flex-direction:column;">
      <span onclick="closeLightbox()" style="position:absolute; top:16px; right:20px; color:white; font-size:36px; font-weight:300; cursor:pointer; z-index:100000; line-height:1;">&times;</span>
      <button onclick="prevSlide(event)" style="position:absolute; left:10px; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.2); border:none; color:white; font-size:32px; width:48px; height:48px; border-radius:50%; cursor:pointer; z-index:100000; display:flex; align-items:center; justify-content:center;">&#10094;</button>
      <button onclick="nextSlide(event)" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.2); border:none; color:white; font-size:32px; width:48px; height:48px; border-radius:50%; cursor:pointer; z-index:100000; display:flex; align-items:center; justify-content:center;">&#10095;</button>
      <img id="lightboxImg" src="" style="max-width:90vw; max-height:80vh; object-fit:contain; border-radius:8px; box-shadow:0 8px 40px rgba(0,0,0,0.5);" />
      <div id="lightboxCaption" style="color:white; font-size:15px; margin-top:12px; text-align:center; max-width:80vw;"></div>
      <div id="lightboxCounter" style="color:rgba(255,255,255,0.6); font-size:12px; margin-top:6px;"></div>
    </div>
    <script>
    var lbItems = [];
    var lbIdx = 0;
    var lbZoomScale = 1;
    var lbPanX = 0, lbPanY = 0, lbDragging = false, lbDragStartX = 0, lbDragStartY = 0, lbPanStartX = 0, lbPanStartY = 0;

    function updateLBPan() {
      var img = document.getElementById('lightboxImg');
      img.style.transform = 'scale(' + lbZoomScale + ') translate(0px, ' + lbPanY + 'px)';
    }

    function collectGalleryImages() {
      lbItems = [];
      document.querySelectorAll('.gallery-grid[data-gallery-group] .gallery-item[data-url]').forEach(function(el) {
        lbItems.push({ url: el.getAttribute('data-url'), title: el.getAttribute('data-title') || '' });
      });
    }

    function openLightbox(el) {
      collectGalleryImages();
      var url = el.getAttribute('data-url');
      lbIdx = lbItems.findIndex(function(i) { return i.url === url; });
      if (lbIdx === -1) lbIdx = 0;
      showSlide();
      document.getElementById('galleryLightbox').style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function showSlide() {
      if (!lbItems.length) return;
      lbZoomScale = 1;
      lbPanY = 0;
      document.getElementById('lightboxImg').style.transform = 'scale(1)';
      document.getElementById('lightboxImg').src = lbItems[lbIdx].url;
      document.getElementById('lightboxCaption').textContent = lbItems[lbIdx].title;
      document.getElementById('lightboxCounter').textContent = (lbIdx + 1) + ' / ' + lbItems.length;
    }

    function nextSlide(e) {
      if (e) e.stopPropagation();
      lbIdx = (lbIdx + 1) % lbItems.length;
      showSlide();
    }

    function prevSlide(e) {
      if (e) e.stopPropagation();
      lbIdx = (lbIdx - 1 + lbItems.length) % lbItems.length;
      showSlide();
    }

    function closeLightbox() {
      document.getElementById('galleryLightbox').style.display = 'none';
      document.body.style.overflow = '';
    }

    document.getElementById('galleryLightbox').addEventListener('click', function(e) {
      if (e.target === this) closeLightbox();
    });

    document.addEventListener('keydown', function(e) {
      if (document.getElementById('galleryLightbox').style.display !== 'flex') return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextSlide();
      if (e.key === 'ArrowLeft') prevSlide();
    });

    var touchStartX = 0;
    document.getElementById('galleryLightbox').addEventListener('touchstart', function(e) { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    document.getElementById('galleryLightbox').addEventListener('touchend', function(e) {
      var diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) { diff > 0 ? nextSlide() : prevSlide(); }
    }, { passive: true });

    document.getElementById('galleryLightbox').addEventListener('wheel', function(e) {
      e.preventDefault();
      var img = document.getElementById('lightboxImg');
      if (e.deltaY < 0) { lbZoomScale = Math.min(lbZoomScale + 0.15, 5); }
      else { lbZoomScale = Math.max(lbZoomScale - 0.15, 0.5); }
      if (lbZoomScale <= 1) { lbPanY = 0; }
      img.style.transition = 'transform 0.15s ease';
      updateLBPan();
    }, { passive: false });

    document.getElementById('lightboxImg').addEventListener('mousedown', function(e) {
      if (lbZoomScale <= 1) return;
      e.preventDefault();
      lbDragging = true;
      lbDragStartX = e.clientX;
      lbDragStartY = e.clientY;
      lbPanStartX = 0;
      lbPanStartY = lbPanY;
      document.getElementById('lightboxImg').style.transition = 'none';
      document.getElementById('galleryLightbox').style.cursor = 'grabbing';
    });

    document.addEventListener('mousemove', function(e) {
      if (!lbDragging) return;
      lbPanY = lbPanStartY + (e.clientY - lbDragStartY) / lbZoomScale;
      updateLBPan();
    });

    document.addEventListener('mouseup', function() {
      lbDragging = false;
      document.getElementById('galleryLightbox').style.cursor = '';
    });
    </script>

