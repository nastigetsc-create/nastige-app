      #popupNoticeOverlay .popup-body p { font-size: 13px !important; line-height: 1.5 !important; }
      #popupNoticeOverlay .popup-body a, #popupNoticeOverlay .popup-body button { padding: 10px !important; font-size: 13px !important; }
    }
    @media (max-width: 480px) {
      #popupNoticeOverlay { padding: 10px !important; }
      #popupNoticeOverlay .popup-content { border-radius: 8px !important; box-shadow: 0 10px 30px rgba(0,0,0,0.25) !important; }
      #popupNoticeOverlay .popup-header { padding: 12px 10px !important; }
      #popupNoticeOverlay .popup-header h2 { font-size: 14px !important; }
      #popupNoticeOverlay .popup-body { padding: 20px; }
      #popupNoticeOverlay .popup-body p { font-size: 12px !important; line-height: 1.4 !important; margin-bottom: 14px !important; }
      #popupNoticeOverlay .popup-body a, #popupNoticeOverlay .popup-body button { padding: 8px 12px !important; font-size: 12px !important; border-radius: 6px !important; }
