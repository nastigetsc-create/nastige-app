      <a href="<%= ig %>" target="_blank" rel="noopener" class="social-sidebar-btn instagram" title="Instagram" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;background:linear-gradient(45deg,#f09433,#e6683c,#dc2743);color:white;text-decoration:none;border-radius:50%;"><i class="fab fa-instagram"></i></a>
      <% } %>
      <% if (yt) { %>
      <a href="<%= yt %>" target="_blank" rel="noopener" class="social-sidebar-btn youtube" title="YouTube" style="display:flex;align-items:center;justify-content:center;width:36px;height:36px;background:#ff0000;color:white;text-decoration:none;border-radius:50%;"><i class="fab fa-youtube"></i></a>
      <% } %>
      </div>

  <script>
    // Banner Track Slide Functions
    (function() {
      const track = document.getElementById('bannerTrack');
      const slides = track ? track.querySelectorAll('.banner-slide') : [];
      if (slides.length === 0) return;
      
      let currentIdx = 0;
      let autoInterval;
      const totalSlides = slides.length;
      
      function updateSlide() {
        track.style.transform = 'translateX(-' + (currentIdx * 100) + '%)';
        var dots = document.querySelectorAll('.banner-dot');
        dots.forEach(function(d, i) {
          d.style.background = i === currentIdx ? '#f97316' : '#ffffff';
        });
      }
      
      window.nextBanner = function() {
        currentIdx = (currentIdx + 1) % totalSlides;
        updateSlide();
        resetAutoSlide();
      };
      
      window.prevBanner = function() {
        currentIdx = (currentIdx - 1 + totalSlides) % totalSlides;
        updateSlide();
        resetAutoSlide();
      };
      
      window.goToBanner = function(idx) {
        currentIdx = idx;
        updateSlide();
        resetAutoSlide();
      };
      
      function resetAutoSlide() {
        clearInterval(autoInterval);
        autoInterval = setInterval(window.nextBanner, 5000);
      }
      
      // Start auto slide
      autoInterval = setInterval(window.nextBanner, 5000);

      // Touch swipe support
      let touchStartX = 0;
      let touchEndX = 0;
      const bannerEl = track.parentElement;
      bannerEl.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      bannerEl.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) window.nextBanner();
          else window.prevBanner();
        }
      }, { passive: true });
    })();

    // Mobile Menu Toggle
    var mobileMenuBtn = document.getElementById('mobileMenuToggle');
    var navMenu = document.getElementById('navMenu');
    
    function toggleMobileMenu(show) {
      if (!mobileMenuBtn || !navMenu) return;
      if (show === undefined) {
        mobileMenuBtn.classList.toggle('active');
        navMenu.classList.toggle('show');
      } else if (show) {
        mobileMenuBtn.classList.add('active');
        navMenu.classList.add('show');
      } else {
        mobileMenuBtn.classList.remove('active');
        navMenu.classList.remove('show');
      }
    }
    
    if (mobileMenuBtn && navMenu) {
        mobileMenuBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            toggleMobileMenu();
        });
        
        navMenu.querySelectorAll('a').forEach(function(link) {
            link.addEventListener('click', function() {
                toggleMobileMenu(false);
            });
        });
        
        document.addEventListener('click', function(e) {
            if (!mobileMenuBtn.contains(e.target) && !navMenu.contains(e.target)) {
                toggleMobileMenu(false);
            }
        });
        
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                toggleMobileMenu(false);
            }
        });
    }

    // Simple scroll animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.feature-card, .product-card, .category-card').forEach(el => {
      observer.observe(el);
    });
  </script>
  <script src="/lightbox.js"></script>
</body>
</html>
