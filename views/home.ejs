      #popupNoticeOverlay .popup-body p { font-size: 11px !important; }
      #popupNoticeOverlay .popup-body a, #popupNoticeOverlay .popup-body button { font-size: 11px !important; }
    }
    @keyframes popupSlide {
      from { opacity: 0; transform: scale(0.9); }
      to { opacity: 1; transform: scale(1); }
    }
  </style>
  <% } %>
