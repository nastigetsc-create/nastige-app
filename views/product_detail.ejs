<!doctype html>
<html lang="en-IN">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= (typeof product !== 'undefined' && product) ? product.name : 'Product Not Found' %> | Nastige</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #667eea; --secondary: #764ba2; --accent: #f093fb; --success: #10b981; --warning: #f59e0b; --danger: #ef4444; --dark: #1e293b; --light: #f8fafc; --card-bg: #ffffff; --border: #e2e8f0; --radius: 16px; --radius-lg: 20px; }
    * { box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #1e293b 0%, #0f172a 50%, #1e293b 100%); min-height: 100vh; margin: 0; padding: 20px; }
    .product-detail { max-width: 1200px; margin: 0 auto; background: linear-gradient(145deg, #ffffff, #f8fafc); border-radius: var(--radius-lg); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15); overflow: hidden; }
    .breadcrumb { padding: 16px 20px; background: linear-gradient(to right, #f8fafc, #f1f5f9); border-bottom: 1px solid var(--border); }
    .breadcrumb a { color: var(--primary); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
      margin-bottom: 24px;
      color: #64748b;
    }

    .breadcrumb a {
      color: #0b5ed7;
      text-decoration: none;
    }

    .product-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      background: white;
      border-radius: 16px;
      padding: 40px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      margin-bottom: 40px;
    }

    .product-gallery {
      position: sticky;
      top: 100px;
      height: fit-content;
    }

    .main-image {
      width: 100%;
      aspect-ratio: 1;
      background: linear-gradient(145deg, #f0f4ff 0%, #e8ecf8 50%, #f8f9ff 100%);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
      overflow: hidden;
      position: relative;
      box-shadow: 0 8px 32px rgba(102, 126, 234, 0.12), inset 0 1px 0 rgba(255,255,255,0.8);
      border: 1px solid rgba(255,255,255,0.6);
      cursor: zoom-in;
    }

    .main-image:hover .zoom-badge {
      opacity: 0;
    }

    .zoom-badge {
      position: absolute;
      bottom: 14px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.6);
      color: white;
      font-size: 12px;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 20px;
      display: flex;
      align-items: center;
      gap: 5px;
      opacity: 1;
      transition: opacity 0.3s;
      pointer-events: none;
      z-index: 2;
    }

    .main-image::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 30% 30%, rgba(102, 126, 234, 0.06) 0%, transparent 50%);
      pointer-events: none;
    }

    .main-image img {
      max-width: 85%;
      max-height: 85%;
      object-fit: contain;
      transition: transform 0.4s ease-out;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,0.08));
      transform-origin: center center;
    }

    .main-image .no-img {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      font-weight: 800;
      color: #fff;
      box-shadow: 0 8px 24px rgba(102, 126, 234, 0.3);
    }

    .thumbnail-list {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .thumbnail {
      width: 80px;
      height: 80px;
      border-radius: 14px;
      background: linear-gradient(145deg, #f8fafc, #f1f5f9);
      border: 2px solid transparent;
      cursor: pointer;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .thumbnail:hover {
      border-color: rgba(102, 126, 234, 0.4);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(102, 126, 234, 0.15);
    }

    .thumbnail.active {
      border-color: var(--primary);
      box-shadow: 0 4px 16px rgba(102, 126, 234, 0.25);
    }

    .thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 6px;
    }

    .zoom-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.85);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      cursor: zoom-out;
      backdrop-filter: blur(8px);
    }

    .zoom-overlay.show {
      display: flex;
    }

    .zoom-overlay img {
      max-width: 90%;
      max-height: 90%;
      object-fit: contain;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      animation: zoomIn 0.3s ease-out;
    }

    .zoom-overlay .close-zoom {
      position: absolute;
      top: 20px; right: 24px;
      color: #fff;
      font-size: 32px;
      cursor: pointer;
      background: rgba(255,255,255,0.15);
      width: 48px; height: 48px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }

    .zoom-overlay .close-zoom:hover {
      background: rgba(255,255,255,0.3);
    }

    @keyframes zoomIn {
      from { transform: scale(0.8); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .product-info h1 {
      font-size: 32px;
      font-weight: 800;
      color: #1a202c;
      margin: 0 0 16px 0;
      line-height: 1.2;
    }

    .product-tag {
      display: inline-block;
      background: #0b5ed7;
      color: white;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 24px;
    }

    .product-price {
      font-size: 36px;
      font-weight: 800;
      color: #0b5ed7;
      margin-bottom: 8px;
    }

    .product-bv {
      font-size: 18px;
      color: #64748b;
      margin-bottom: 24px;
    }

    .product-description {
      line-height: 1.8;
      color: #475569;
      margin-bottom: 32px;
      padding: 24px;
      background: #f8fafc;
      border-radius: 12px;
    }

    .product-actions {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 16px 32px;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 600;
      font-size: 16px;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: none;
      cursor: pointer;
    }

    .btn-primary {
      background: #0b5ed7;
      color: white;
      box-shadow: 0 8px 25px rgba(11, 94, 215, 0.3);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 35px rgba(11, 94, 215, 0.4);
    }

    .btn-secondary {
      background: white;
      color: #0b5ed7;
      border: 2px solid #0b5ed7;
    }

    .btn-secondary:hover {
      background: #0b5ed7;
      color: white;
    }

    .benefits-section {
      background: white;
      border-radius: 16px;
      padding: 40px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      margin-bottom: 40px;
    }

    .benefits-section h2 {
      font-size: 24px;
      font-weight: 700;
      color: #1a202c;
      margin: 0 0 24px 0;
    }

    .benefits-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .benefit-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 16px;
      background: #f8fafc;
      border-radius: 12px;
    }

    .benefit-icon {
      font-size: 24px;
      flex-shrink: 0;
    }

    .benefit-text {
      color: #475569;
      line-height: 1.6;
    }

    @media (max-width: 768px) {
      .product-container {
        grid-template-columns: 1fr;
        padding: 24px;
      }

      .product-gallery {
        position: static;
      }

      .product-info h1 {
        font-size: 24px;
      }

      .product-price {
        font-size: 28px;
      }

      .product-actions {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <%- include('_public_header') %>

  <div class="product-detail">
    <% if (error) { %><div style="padding:16px; background:#fee2e2; color:#dc2626; margin:12px; border-radius:8px"><%= error %></div><% } %>
    <% if (success) { %><div style="padding:16px; background:#d1fae5; color:#059669; margin:12px; border-radius:8px"><%= success %></div><% } %>
    
    <div class="breadcrumb">
      <a href="<%= user ? '/products' : '/home' %>">← Back to <%= user ? 'Products' : 'Home' %></a>
    </div>

    <% if (product) { %>
    <div class="product-container">
      <div class="product-gallery">
        <div class="main-image" <% if (user) { %>onclick="openZoom()" <% } %>>
          <% if (product.image_url) { %>
            <img src="<%= product.image_url %>" alt="<%= product.name %>" id="mainImg"/>
            <div class="zoom-badge">🔍 Hover to Zoom</div>
          <% } else { %>
            <div class="no-img"><%= product.name.charAt(0) %></div>
          <% } %>
        </div>
        <% if (product.images && product.images.length > 1) { %>
          <div class="thumbnail-list">
            <% product.images.forEach((img, idx) => { %>
              <div class="thumbnail <%= idx === 0 ? 'active' : '' %>" onclick="changeImage('<%= img %>', this)">
                <img src="<%= img %>" alt="<%= product.name %> - Image <%= idx + 1 %>"/>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <% if (user) { %>
      <div class="zoom-overlay" id="zoomOverlay" onclick="closeZoom()">
        <div class="close-zoom" onclick="closeZoom()">✕</div>
        <img id="zoomImg" src="" alt="Zoomed view"/>
      </div>
      <% } %>

      <div class="product-info">
        <h1><%= product.name %></h1>
        <span class="product-tag"><%= product.tag %></span>
        <div class="product-price"><%= user ? 'DP: ' : 'MRP: ' %><%= rupee.format(product.price_inr) %></div>
        <div class="product-bv">BV Points: <strong><%= product.pv %></strong></div>

        <% if (product.description) { %>
          <div class="product-description">
            <%- product.description %>
          </div>
        <% } %>

        <div class="product-actions">
          <% if (user) { %>
            <form method="POST" action="/user/orders" style="display:inline;">
              <input type="hidden" name="product_id" value="<%= product.id %>">
              <input type="hidden" name="quantity" value="1" id="qty-input">
              <button type="submit" class="btn btn-primary" onclick="return confirm('Place order for <%= product.name %>?')">Buy Now</button>
            </form>
            <a href="/user/orders" class="btn btn-secondary">View My Orders</a>
          <% } else { %>
            <a href="/signup" class="btn btn-primary">Join to Buy</a>
          <% } %>
          <a href="<%= user ? '/products' : '/home' %>" class="btn btn-secondary"><%= user ? 'View All Products' : 'Back to Home' %></a>
        </div>
      </div>
    </div>
    <% } %>

    <div class="benefits-section">
      <h2>Why Choose This Product?</h2>
      <div class="benefits-list">
        <div class="benefit-item">
          <div class="benefit-icon">✓</div>
          <div class="benefit-text">100% genuine and authentic product with quality assurance</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">🚚</div>
          <div class="benefit-text">Free shipping on orders above ₹20,000</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">💰</div>
          <div class="benefit-text">Earn <%= product.pv %> BV points towards your income</div>
        </div>
        <div class="benefit-item">
          <div class="benefit-icon">↩️</div>
          <div class="benefit-text">As per company return and refund policy</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function changeImage(src, thumb) {
      document.getElementById('mainImg').src = src;
      document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
      thumb.classList.add('active');
    }

    var mainImg = document.getElementById('mainImg');
    var mainImgContainer = document.querySelector('.main-image');
    if (mainImg && mainImgContainer) {
      var targetX = 50, targetY = 50, currentX = 50, currentY = 50;
      var animFrame = null;
      function smoothZoom() {
        currentX += (targetX - currentX) * 0.15;
        currentY += (targetY - currentY) * 0.15;
        mainImg.style.transformOrigin = currentX + '% ' + currentY + '%';
        mainImg.style.transform = 'scale(2)';
        animFrame = requestAnimationFrame(smoothZoom);
      }
      mainImgContainer.addEventListener('mousemove', function(e) {
        var rect = mainImgContainer.getBoundingClientRect();
        targetX = ((e.clientX - rect.left) / rect.width) * 100;
        targetY = ((e.clientY - rect.top) / rect.height) * 100;
        if (!animFrame) animFrame = requestAnimationFrame(smoothZoom);
      });
      mainImgContainer.addEventListener('mouseleave', function() {
        if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
        currentX = 50; currentY = 50; targetX = 50; targetY = 50;
        mainImg.style.transformOrigin = 'center center';
        mainImg.style.transform = 'scale(1)';
      });
    }

    <% if (user) { %>
    function openZoom() {
      var img = document.getElementById('mainImg');
      if (!img || !img.src) return;
      document.getElementById('zoomImg').src = img.src;
      document.getElementById('zoomOverlay').classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function closeZoom() {
      document.getElementById('zoomOverlay').classList.remove('show');
      document.body.style.overflow = '';
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeZoom();
    });
    <% } %>
  </script>
</body>
</html>