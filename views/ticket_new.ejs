<!doctype html>
<html lang="en-IN">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>New Ticket | Nastige</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/user-panel.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
</head>
<body>
  <div class="page-wrapper">
    <div class="page-header">
      <div class="page-header-left">
        <img src="/brand/logo" class="page-header-logo" alt="Logo" onerror="this.style.display='none'"/>
        <div>
          <h2 style="margin:0; font-size:20px;">Create Ticket</h2>
          <p style="margin:4px 0 0; opacity:0.9; font-size:13px;">Submit Your Query</p>
        </div>
      </div>
      <div class="page-header-right">
        <a href="/tickets" class="back-btn"><i class="fas fa-arrow-left"></i> Tickets</a>
      </div>
    </div>
<div class="content"><% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <div class="card" style="max-width:600px; margin:0 auto;">
      <div class="card-header"><i class="fas fa-plus-circle" style="color:#10b981; margin-right:8px;"></i> New Support Ticket</div>
      <div class="card-body">
        <form method="post" action="/tickets" enctype="multipart/form-data">
          <div class="form-group">
            <label><i class="fas fa-heading"></i> Subject</label>
            <input name="subject" class="form-control" placeholder="Enter ticket subject" required/>
          </div>
          <div class="form-group">
            <label><i class="fas fa-align-left"></i> Description</label>
            <textarea name="message" class="form-control" rows="5" placeholder="Describe your issue in detail..." required></textarea>
          </div>
          <div class="form-group">
            <label><i class="fas fa-paperclip"></i> Attach Document (Optional)</label>
            <input type="file" name="ticket_file" class="form-control" accept="image/*,.pdf,.doc,.docx"/>
            <div style="font-size:11px; color:#94a3b8; margin-top:4px;">Supported: Images, PDF, DOC (Max 10MB)</div>
          </div>
          <button type="submit" class="btn btn-success" style="width:100%;"><i class="fas fa-paper-plane"></i> Submit Ticket</button>
        </form>
      </div>
    </div>
  </div>
  </div>
  </div>
<script>document.querySelectorAll('.side-link').forEach(function(l){var p=l.getAttribute('href');if(window.location.pathname===p||(p!=='/admin'&&window.location.pathname.startsWith(p)))l.classList.add('active')});</script>
</body>
</html>
